# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Drizzle / direct Postgres connection (use the connection string from Supabase Settings → Database)
# Use the "Session" pooler URL for migrations and the "Transaction" pooler for the app runtime.
DATABASE_URL=postgres://postgres.YOUR-PROJECT:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_DIRECT_URL=postgres://postgres.YOUR-PROJECT:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Admin allowlist — comma-separated emails that get admin role on first login
ADMIN_EMAILS=ramon.romero@unnax.com

# App branding
NEXT_PUBLIC_APP_NAME="Copa Mundial de la FIFA 2026"

# Tournament timing — used to gate visibility of pre-tournament predictions
NEXT_PUBLIC_TOURNAMENT_KICKOFF_AT=2026-06-11T20:00:00Z
